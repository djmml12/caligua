# Forzar LF en todos los archivos de texto para evitar problemas Windows↔Linux
* text=auto eol=lf

# Scripts bash — siempre LF, nunca CRLF
*.sh        text eol=lf

# Código fuente
*.js        text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.jsx       text eol=lf
*.css       text eol=lf
*.html      text eol=lf

# Config / data
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.env       text eol=lf
*.env.*     text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.conf      text eol=lf
*.toml      text eol=lf

# Binarios — sin conversión
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       text eol=lf
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.pdf       binary
